{
  "name": "homekit-camera-proxy",
  "version": "0.2.0",
  "description": "Minimal HomeKit bridge for Frigate cameras: live streaming, snapshots, motion sensors, two-way audio, doorbell",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@homebridge/hap-nodejs": "^2.1.8",
    "onvif": "^0.7.1",
    "ws": "^8.18.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
